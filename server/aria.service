[Unit]
Description=AR.IA Streamlit
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/aria/app
ExecStart=/home/ubuntu/aria/venv/bin/streamlit run aria.py --server.port 8501 --server.address 127.0.0.1 --server.headless true
Restart=always
Environment=OPENAI_API_KEY=REMPLACER_PAR_TA_CLE

[Install]
WantedBy=multi-user.target
